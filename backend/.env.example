GCS_BUCKET_NAME=courtvision-videos
GOOGLE_APPLICATION_CREDENTIALS=

GEMINI_API_KEY=your_gemini_api_key_here

FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./courtvision.db

# JWT — change to a long random string in production
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Google OAuth — create a project at console.cloud.google.com and enable Google Sign-In
# Credentials > Create OAuth 2.0 Client ID > Web Application
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
